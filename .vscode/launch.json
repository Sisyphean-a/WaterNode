{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Debug",
      "request": "launch",
      "type": "dart",
      "deviceId": "${input:flutterDevice}"
    },
    {
      "name": "Flutter Windows",
      "request": "launch",
      "type": "dart",
      "deviceId": "windows"
    },
    {
      "name": "Flutter Android",
      "request": "launch",
      "type": "dart",
      "deviceId": "android"
    }
  ],
  "inputs": [
    {
      "id": "flutterDevice",
      "type": "pickString",
      "description": "选择调试设备",
      "default": "windows",
      "options": [
        "windows",
        "android"
      ]
    }
  ]
}
